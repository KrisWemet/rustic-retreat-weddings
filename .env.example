# Chatbot (server runtime in Vercel Functions)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=your_model_id
OPENROUTER_SITE_URL=https://rustic-retreat-weddings.vercel.app

# Frontend Sanity content (public read)
VITE_SANITY_PROJECT_ID=your_sanity_project_id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-10-01
VITE_SANITY_USE_CDN=true
VITE_SANITY_STUDIO_URL=http://localhost:3333

# Server-side Sanity config (Vercel Functions)
SANITY_PROJECT_ID=your_sanity_project_id
SANITY_DATASET=production
SANITY_API_VERSION=2024-10-01
SANITY_STUDIO_URL=https://your-studio-host
SANITY_VIEWER_TOKEN=your_sanity_viewer_token

# Sanity Studio local config
SANITY_STUDIO_PROJECT_ID=your_sanity_project_id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_PREVIEW_ORIGIN=http://localhost:8080
# Optional: set true only when running site via Vercel Functions for draft-cookie preview mode
SANITY_ENABLE_PREVIEW_MODE=false
